# ==============================================
# WEZU BATTERY APP - BACKEND CONFIGURATION
# ==============================================

# ----------------------------------------------
# Application Settings
# ----------------------------------------------
PROJECT_NAME="WEZU Energy"
APP_NAME="Wezu Battery App"
API_V1_STR=/api/v1

ENVIRONMENT=development
DEBUG=true


# ----------------------------------------------
# Database (Neon PostgreSQL - Correct)
# ----------------------------------------------
DATABASE_URL="postgresql://neondb_owner:npg_5JgZ7QGrPLAx@ep-twilight-cherry-aip86ui8-pooler.c-4.us-east-1.aws.neon.tech/wezu_battery?sslmode=require&channel_binding=require"


# ----------------------------------------------
# Redis (Sessions & Caching)
# ----------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2


# ----------------------------------------------
# Security & JWT Authentication
# ----------------------------------------------
SECRET_KEY=your-secret-key-min-32-characters-long-change-this-in-production
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30


# ==============================================
# CUSTOMER AUTHENTICATION
# ==============================================

# Google OAuth (Customer Social Login)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Apple Sign In (Customer Social Login)
APPLE_CLIENT_ID=com.wezu.batteryapp
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=/path/to/apple-private-key.p8


# ----------------------------------------------
# SMS / OTP Authentication
# ----------------------------------------------
SMS_PROVIDER=twilio

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=WEZUBT

OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6


# ==============================================
# CUSTOMER SERVICES
# ==============================================

# Push Notifications (Firebase Cloud Messaging)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FCM_SERVER_KEY=your-fcm-server-key


# ----------------------------------------------
# Payment Gateway (Razorpay)
# ----------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_MERCHANT_NAME="WEZU Energy"


# ----------------------------------------------
# Maps & Location Services
# ----------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-token
DEFAULT_MAP_PROVIDER=google


# ----------------------------------------------
# Video KYC Provider
# ----------------------------------------------
VIDEO_KYC_PROVIDER=agora
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate
VIDEO_KYC_SESSION_TIMEOUT_MINUTES=30


# ----------------------------------------------
# IoT / MQTT (Battery Tracking)
# ----------------------------------------------
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=wezu_mqtt_user
MQTT_PASSWORD=mqtt_password

MQTT_CLIENT_ID_PREFIX=wezu_backend
MQTT_TOPIC_PREFIX=wezu/batteries


# ==============================================
# FILE STORAGE
# ==============================================

STORAGE_PROVIDER=aws_s3

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

AWS_BUCKET_NAME=wezu-customer-assets
AWS_REGION=ap-south-1
AWS_S3_CUSTOM_DOMAIN=cdn.wezu.com

LOCAL_STORAGE_PATH=/var/www/uploads
MAX_UPLOAD_SIZE_MB=10


# ==============================================
# CUSTOMER NOTIFICATIONS
# ==============================================

# Email Notifications (SendGrid)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@wezu.com

EMAILS_FROM_NAME="WEZU Energy"
EMAILS_ENABLED=true


# ==============================================
# CUSTOMER APP SETTINGS
# ==============================================

# Rental Rules
MIN_BATTERY_SOC_FOR_RENTAL=20
MAX_ACTIVE_RENTALS_PER_USER=1
RENTAL_GRACE_PERIOD_HOURS=2

LATE_FEE_MULTIPLIER=1.5
SWAP_FEE_PERCENTAGE=0.0


# ----------------------------------------------
# Geofencing Alerts
# ----------------------------------------------
GEOFENCE_CHECK_INTERVAL_MINUTES=60
GEOFENCE_ALERT_ENABLED=true


# ----------------------------------------------
# Rate Limiting (API Protection)
# ----------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000


# ==============================================
# BACKGROUND JOBS
# ==============================================

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Kolkata


# ==============================================
# LOGGING & MONITORING
# ==============================================

LOG_LEVEL=INFO

# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1


# ==============================================
# CUSTOMER SUPPORT
# ==============================================

SUPPORT_EMAIL=support@wezu.com
SUPPORT_PHONE=+91-1234567890


# ==============================================
# CORS SETTINGS
# ==============================================

CORS_ORIGINS=["http://localhost:3000","https://app.wezu.com"]
