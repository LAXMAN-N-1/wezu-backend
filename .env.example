# ==============================================================================
# WEZU BACKEND — ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Generate a secure SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ==============================================================================

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
PROJECT_NAME=WEZU Energy
APP_VERSION=1.0.0
API_V1_STR=/api/v1
ENABLE_API_DOCS=false

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (PostgreSQL / Neon) ───────────────────────────────────────────────
# REQUIRED
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_SSL_MODE=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_POOL_USE_LIFO=true
DATABASE_CONNECT_TIMEOUT_SECONDS=10
# Log queries slower than N ms (0 = disabled)
SQL_SLOW_QUERY_LOG_MS=0

# ── Redis ──────────────────────────────────────────────────────────────────────
# REQUIRED — use redis://:password@host:6379/0 if Redis requires auth
REDIS_URL=redis://127.0.0.1:6379/0

# ── CORS & Hosts ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=["https://app.yourdomain.com","https://admin.yourdomain.com"]
ADMIN_FRONTEND_ORIGIN=https://admin.yourdomain.com
# Comma-separated list of allowed host headers
ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com
ENABLE_TRUSTED_HOST_MIDDLEWARE=true
TRUST_X_FORWARDED_HOST=true
FORWARDED_ALLOW_IPS=127.0.0.1/32,::1/128,172.16.0.0/12

# Public base URLs (used in emails, QR codes, etc.)
API_PUBLIC_BASE_URL=https://api.yourdomain.com
MEDIA_BASE_URL=https://api.yourdomain.com/uploads

# ── Support Contact ────────────────────────────────────────────────────────────
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_PHONE=+91-1234567890

# ── AWS S3 Storage ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER=aws_s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1

# ── OAuth (Google / Apple) ─────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# ── Firebase Push Notifications ────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=/secrets/firebase-credentials.json
FCM_SERVER_KEY=

# ── Payment Gateway (Razorpay) ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── SMS (Twilio / MSG91) ───────────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Set true only in development/testing to bypass real OTP
ALLOW_TEST_OTP_BYPASS=false

# ── Email (SendGrid) ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=

# ── Maps ───────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# ── MongoDB (optional — audit logs) ───────────────────────────────────────────
MONGODB_URL=
MONGODB_DB=wezu_audit

# ── Monitoring & Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# ── Audit & Background Tasks ───────────────────────────────────────────────────
AUDIT_REQUEST_LOGGING_ENABLED=true
RUN_BACKGROUND_TASKS=true
SCHEDULER_ENABLED=true

# ── Gunicorn (production server) ───────────────────────────────────────────────
# Workers: (2 × CPU cores) + 1  is a common starting point
GUNICORN_WORKERS=3
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=65
GUNICORN_MAX_REQUESTS=1200
GUNICORN_MAX_REQUESTS_JITTER=120
PORT=8000
