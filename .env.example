# ==============================================================================
# WEZU ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# COPY THIS FILE TO .env AND POPULATE WITH REAL VALUES
# NEVER COMMIT .env TO VERSION CONTROL

# Application Core
ENVIRONMENT=development
DEBUG=True
PROJECT_NAME="WEZU Energy"
API_V1_STR=/api/v1
APP_NAME="Wezu Battery App"
CORS_ORIGINS=["http://localhost:3000"]
SUPPORT_EMAIL=support@wezu.com
SUPPORT_PHONE=+91-1234567890

# Security (Required)
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL Database (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/wezu_db
SQLALCHEMY_ECHO=False
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=3

# Redis (Required for Sessions & Caching)
REDIS_URL=redis://127.0.0.1:6379/0

# MongoDB (Audit Logs / Optional depending on env)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=wezu_audit

# OAuth (Google / Apple)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# Push Notifications (Firebase)
FIREBASE_CREDENTIALS_PATH=/path/to/secure/firebase-credentials.json
FCM_SERVER_KEY=

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SMS Providers (Twilio/MSG91)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Maps API
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# AWS S3 Storage
STORAGE_PROVIDER=aws_s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1

# Monitoring & Logging
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
